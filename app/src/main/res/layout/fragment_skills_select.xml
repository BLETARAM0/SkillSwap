<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:padding="24dp">

    <!-- Question: What you can teach? -->
    <TextView
        android:id="@+id/tvTeachQuestion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="What can you teach?"
        android:textSize="18sp"
        android:textStyle="bold"/>

    <!-- Teach Spinner -->
    <Spinner
        android:id="@+id/spTeach"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"/>

    <!-- Question: What you want to study? -->
    <TextView
        android:id="@+id/tvLearnQuestion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="What do you want to study?"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginTop="24dp"/>

    <!-- Learn Spinner -->
    <Spinner
        android:id="@+id/spStudy"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"/>

    <!-- Next Button -->
    <Button
        android:id="@+id/btnNext"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Next"
        android:layout_gravity="end"
        android:layout_marginTop="40dp"
        android:layout_marginEnd="24dp"/>

</LinearLayout>